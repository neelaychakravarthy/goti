# Frontend env vars for local dev. Copy to `web/.env.local` and fill in.
# Next.js reads env files from THIS directory (web/), not the repo root.

# Public base URL of the backend. Use the local docker-compose api in
# dev; swap for your Zeabur deployment URL in production.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# NextAuth session cookie secret. Generate with: `openssl rand -base64 32`
# Auth.js v5 reads AUTH_SECRET by default; we accept NEXTAUTH_SECRET too.
NEXTAUTH_SECRET=

# Google OAuth credentials — get from Google Cloud Console → Credentials
# → Create OAuth 2.0 Client ID (Web application). Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google   (local dev)
#   https://<your-vercel-url>/api/auth/callback/google   (production)
# The CLIENT_ID must match the backend's `GOOGLE_OAUTH_CLIENT_ID` (same value).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public mirror of GOOGLE_OAUTH_CLIENT_ID — Next.js inlines NEXT_PUBLIC_*
# vars into client-side bundles. Set to the same value.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# NextAuth's own origin. localhost for dev; Vercel URL for prod.
NEXTAUTH_URL=http://localhost:3000
