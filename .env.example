# AI / LLM
Z_AI_API_KEY=
TOKENROUTER_API_KEY=
ANTHROPIC_API_KEY=
# TokenRouter routing string for Z.AI GLM-5.1. Per Pass-1 research: TokenRouter
# is OpenAI-compatible and likely accepts the OpenRouter-namespace convention
# `z-ai/glm-5.1`. Override if docs.tokenrouter.io specifies otherwise.
GLM_MODEL_ID=z-ai/glm-5.1

# Discovery
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=

# Marketplace automation (Actionbook is an MCP server fronted by Clerk OAuth.
# Dynamic Client Registration RFC 7591 — Goti registers itself at first link
# request; no pre-arranged client credentials. SPEC.md "Required sponsors / Actionbook".)
ACTIONBOOK_MCP_URL=https://edge.actionbook.dev/mcp
ACTIONBOOK_OAUTH_ISSUER=https://clerk.actionbook.dev
# Set this to your deployed API base + the callback path (used in the OAuth redirect URL).
# Default below is for local dev via docker-compose. `{provider}` is interpolated to fb / nextdoor.
ACTIONBOOK_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/{provider}/oauth/callback
# Optional: if your deployment has a pre-registered Clerk OAuth client_id (e.g. to survive
# container restarts without re-running dynamic registration), set it here to skip the
# RFC 7591 dance. Leave blank to dynamically register on first link request.
#ACTIONBOOK_OAUTH_REGISTERED_CLIENT_ID=

# Agent memory (EverOS reads EVEROS_API_KEY from env directly)
EVEROS_API_KEY=

# AgentField control plane (only override if running outside docker-compose)
AF_CONTROL_PLANE_URL=http://localhost:8080

# Mock-externals gate — set to 1 to swap real Bright Data / Actionbook /
# EverOS calls for deterministic fixtures (used by Streams A + B for offline dev).
GOTI_USE_MOCKS=0

# App
DATABASE_URL=postgresql+asyncpg://goti:goti@localhost:5432/goti
# Frontend points at the Zeabur-deployed backend in prod; localhost in local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_SECRET=
