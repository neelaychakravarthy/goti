# AI / LLM — Anthropic Claude. Single key powers every reasoner
# (clarifier, valuation, negotiation drafter) AND every browser-use
# Agent step (discovery, send, fetch). Get a key at
# https://console.anthropic.com/.
ANTHROPIC_API_KEY=
# Reasoner model id — clarifier / valuation / negotiation drafter. Short
# JSON outputs; Haiku 4.5 is plenty.
CLAUDE_MODEL_ID=claude-haiku-4-5-20251001
# Browser-agent model id — used by browser-use's per-step Agent loop.
# The AgentOutput schema (thinking + memory + next_goal + list[action])
# is large, and Haiku occasionally drops the required ``action`` field
# under tool-call pressure. Sonnet handles it reliably.
CLAUDE_BROWSER_MODEL_ID=claude-sonnet-4-6

# Marketplace automation (Browserbase). Goti owns a single API key +
# project id; per-user Browserbase Contexts persist FB / Nextdoor /
# OfferUp / Craigslist cookies across sessions. Get both from
# https://browserbase.com/dashboard — one key serves all Goti users via
# the Contexts API.
#
# The same Browserbase context drives BOTH discovery (search
# marketplaces, scrape listings) AND negotiation (send messages, fetch
# replies) via the browser-use AI agent — Claude reasons through the
# marketplace DOM in natural language.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Concurrent-session ceiling. Bound by Browserbase's per-project quota
# (free=3, Developer=25, Startup=100). Goti uses an in-process
# semaphore to never exceed this — discovery iterations + parallel
# negotiation jobs all consume permits. Set to your tier's ceiling (or
# 1 below if you want a slot reserved for Live View logins).
#
# NOTE: Browserbase ALSO meters monthly browser-minutes (free=60).
# Once exhausted, every session.create returns 402 Payment Required.
# Goti surfaces a dedicated "Upgrade Browserbase" banner when this
# happens — see the Browserbase quotas section in README.md.
BROWSERBASE_MAX_CONCURRENT=24

# Agent memory (EverOS reads EVEROS_API_KEY from env directly)
EVEROS_API_KEY=

# AgentField control plane — FastAPI itself is the control plane (see
# `api/routes/agent_bridge.py`). Reasoners (running on :8080 in the same
# container/pod) call this URL for request-approval / heartbeats / etc.
# Override only if FastAPI binds to a different port.
AF_CONTROL_PLANE_URL=http://localhost:8000

# AgentField agent server — where the reasoner agent process listens
# (``python -m api.agents.clarifier`` -> ``app.run()`` on :8080). FastAPI's
# orchestration layer POSTs to this URL to invoke reasoners. DO NOT confuse
# this with AF_CONTROL_PLANE_URL above — the agent server is INBOUND from
# FastAPI; the control plane is OUTBOUND from the agent server. Pointing
# this at :8000 makes every reasoner call 404.
AF_AGENT_SERVER_URL=http://localhost:8080

# CORS — comma-separated list of allowed origins for the frontend(s).
# Set this to your Vercel deployment URL in production (e.g.
# `https://goti.vercel.app`). Multiple values comma-separated. Empty
# default falls back to dev-friendly origins (localhost:3000 + *.vercel.app).
GOTI_ALLOWED_ORIGINS=

# App
# Postgres connection. Same var name in dev and prod — on Zeabur the
# Postgres add-on auto-injects this when the postgresql plugin is linked
# to the API service; in local dev set it to the docker-compose / local
# Postgres URL. The backend accepts both the ``postgresql+asyncpg://``
# async form and the standard ``postgresql://`` form (api/config.py
# rewrites the prefix internally so SQLAlchemy gets the asyncpg driver).
POSTGRES_URI=postgresql+asyncpg://goti:goti@localhost:5432/goti
# Frontend points at the Zeabur-deployed backend in prod; localhost in local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_SECRET=
# Vercel production NEXTAUTH_URL — set to the canonical production
# domain (e.g. `https://goti.vercel.app`).
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — multi-tenant sign-in.
# Both frontend (NextAuth Google provider) and backend (ID-token audience
# verification) MUST share the same client_id. Get a pair from
# https://console.cloud.google.com → APIs & Services → Credentials →
# Create OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs: <web-origin>/api/auth/callback/google
# Backend reads GOOGLE_OAUTH_CLIENT_ID; frontend reads both.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Public Google client id mirror — Next.js client components reference
# NEXT_PUBLIC_* env vars at build time. Matches GOOGLE_OAUTH_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
